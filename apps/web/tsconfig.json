{
  "extends": "@acora/typescript-config/base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "rootDirs": ["."],
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@server/*": ["../server/*"]
    }
  },
  "exclude": ["node_modules", "dist"],
  "references": [
    {
      "path": "../server"
    }
  ]
}
