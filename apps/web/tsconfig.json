{
	"compilerOptions": {
		"strict": true,
		"esModuleInterop": true,
		"jsx": "react-jsx",
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"verbatimModuleSyntax": true,
		"skipLibCheck": true,
		"types": ["vite/client"],
		"rootDirs": ["."],
		"baseUrl": ".",
		"paths": {
			"@/*": ["./src/*"],
			"@acora/zod-schemas": ["../../packages/zod-schemas/src"]
		}
	},
	"references": [
		{
			"path": "../server"
		},
		{ "path": "../../packages/zod-schemas" }
	]
}
