{
	"extends": "@acora/typescript-config/base.json",
	"compilerOptions": {
		"composite": true,
		"outDir": "./dist",
		"types": ["node"],
		"jsx": "react-jsx",
		"baseUrl": ".",
		"paths": {
			"@/*": ["./src/*"]
		}
	},
	"tsc-alias": {
		"resolveFullPaths": true
	},
	"exclude": ["node_modules", "dist", "**/*.d.ts", "prisma.config.d.ts"]
}
